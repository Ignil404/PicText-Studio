# PostgreSQL — ОБЯЗАТЕЛЬНО: замени на свои значения
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=dl2026
# DATABASE_URL is derived from POSTGRES_USER/PASSWORD/DB in docker-compose.yml
# Do not set it here unless running outside Docker

# Redis
REDIS_URL=redis://redis:6379/0

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT Authentication
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
